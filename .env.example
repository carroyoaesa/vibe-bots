# Ejemplo de configuración de claves para Vibe Bots

# Alpaca
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# PostgreSQL nativo (usar un rol dedicado, no el superusuario postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vibe
POSTGRES_USER=vibe_bot
POSTGRES_PASSWORD=

# Redis nativo
REDIS_URL=redis://localhost:6379

# MinIO nativo
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vibe-bots
MINIO_REGION=us-east-1

# Financial Modeling Prep (fundamentales) - https://financialmodelingprep.com
FMP_API_KEY=

# Finnhub (quotes, fundamentales, earnings) - https://finnhub.io
FINNHUB_API_KEY=

# Alpha Vantage (quotes, noticias y sentimiento) - https://www.alphavantage.co
# Free tier muy limitado (~25 requests/día), usar con moderación
ALPHA_VANTAGE_API_KEY=

# FRED - Federal Reserve Economic Data (series macro) - https://fred.stlouisfed.org
FRED_API_KEY=

# Dashboard web (Fase 1.5)
WEB_PORT=4000
# URL del Public Dashboard de Grafana ("Vibe Bots - Overview"), para embeber en /
# Se obtiene al compartir el dashboard como "Public dashboard" en Grafana.
GRAFANA_PUBLIC_URL=

# Alertas por email (BUY/SELL ejecutados) - opcional: si falta cualquiera de las 4
# variables marcadas, runTradingCycle() omite el envío en silencio (no rompe el ciclo).
# SMTP genérico (sirve para Gmail con contraseña de aplicación, Outlook, Fastmail,
# un relay SMTP de SendGrid/Mailgun/Resend/SES, etc).
SMTP_HOST=
SMTP_PORT=587
# 'true' para puerto 465 (SSL implícito); con 587/STARTTLS dejar 'false' o sin definir.
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
# Remitente del email (default: SMTP_USER si se omite)
SMTP_FROM=
# Destinatario(s) de la alerta - separar con coma si son varios
ALERT_EMAIL_TO=
